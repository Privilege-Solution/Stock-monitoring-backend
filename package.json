{
  "name": "asw-monitor",
  "private": true,
  "version": "1.1.0",
  "scripts": {
    "build:css": "cd frontend && tailwindcss -i ./src/styles.css -o ./dist/styles.css --minify",
    "watch:css": "cd frontend && tailwindcss -i ./src/styles.css -o ./dist/styles.css --watch",
    "start": "node backend/server.js",
    "dev": "npm run build:css && node backend/server.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.19.2",
    "node-cron": "^3.0.3",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0"
  }
}
