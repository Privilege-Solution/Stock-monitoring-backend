# Copy this file to `.env` and fill in real keys. `.env` is gitignored.
#
#   cp .env.example .env
#   $EDITOR .env

# Postgres connection string — required. Used by db.js for the daily,
# peer_prices, news_feed, and fetch_log tables. Supabase project URL works
# as-is. Without this, server.js crashes at boot with
# "DATABASE_URL not set in environment".
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DBNAME

# Google Gemini API key — powers the Gemini-search pipeline
# (lib/fetchers/gemini-search.mjs uses gemini-2.5-flash with Google Search
# grounding enabled). Runs 4 jobs per week:
#   17:45 ICT daily      gemini-company       → 1 pin to daily.remark + headlines to news_feed
#   17:50 ICT daily      gemini-sector        → 0–3 sector headlines to news_feed
#   17:55 ICT daily      gemini-macro         → 0–2 macro headlines; severity=high → also pin
#   08:00 ICT Monday     gemini-morning-brief → weekly brief to daily.morning_*
# Without this key, the /api/remarks/refresh + /api/news/refresh +
# /api/morning-brief/refresh routes and all 4 cron jobs stay disabled.
GEMINI_API_KEY=

# Optional overrides
# PORT=3000
